{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Документация SpeShu.AI",
  "api": {
    "mdx": {
      "server": "https://speshu.ai/api/v1",
      "auth": {
        "method": "bearer",
        "name": "Authorization"
      }
    }
  },
  "colors": {
    "primary": "#ff7819",
    "light": "#ff9038",
    "dark": "#ff7819"
  },
  "appearance": {
    "default": "light"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "ru",
        "tabs": [
          {
            "tab": "Документация",
            "groups": [
              {
                "group": "Главное",
                "pages": [
                  "index",
                  "quickstart",
                  "principles",
                  "faq",
                  "enterprise",
                  "support",
                  "providers",
                  "privacy"
                ]
              }
            ]
          },
          {
            "tab": "Руководства",
            "groups": [
              {
                "group": "Начало работы",
                "pages": [
                  "gaidy/getting-started",
                  "gaidy/models",
                  "gaidy/chat-completions",
                  "gaidy/media-input"
                ]
              },
              {
                "group": "Продвинутое",
                "pages": [
                  "gaidy/provider-selection",
                  "gaidy/tool-calling",
                  "gaidy/structured-output",
                  "gaidy/plugins",
                  "gaidy/web-search",
                  "gaidy/reasoning-tokens",
