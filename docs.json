          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "Текстовая генерация",
                "pages": [
                  "api-reference/chat/completions"
                ]
              },

              {
                "group": "Модели",
                "pages": [
                  "api-reference/models/list"
                ]
              },

              {
                "group": "Другое",
                "pages": [
                  "api-reference/other/balance"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Модели",
          "href": "/gaidy/models",
          "icon": "microchip"
        },
        {
          "anchor": "Профиль",
          "href": "https://speshu.ai/profile",
          "icon": "gauge"
        },
        {
          "anchor": "Обновления",
          "href": "https://speshu.ai",
          "icon": "clock-rotate-left"
        }
      ]
    }
