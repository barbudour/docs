                      "gaidy/seedance-1-5-pro",
                      "gaidy/kling-3",
                      "gaidy/kling-3-motion-control",
                      "gaidy/kling-2-6-motion-control",
                      "gaidy/wan-2-6",
                      "gaidy/wan-2-5",
                      "gaidy/sora-2-pro",
                      "gaidy/sora-2",
                      "gaidy/kling-2-5-turbo",
                      "gaidy/veo-3-1"
                    ]
                  },
                  {
                    "group": "Изображения",
                    "icon": "image",
                    "pages": [
                      "gaidy/topaz-upscale",
                      "gaidy/seedream-5-lite",
                      "gaidy/seedream-4-5",
                      "gaidy/seedream-4",
                      "gaidy/seedream-3",
                      "gaidy/flux-2-pro",
                      "gaidy/flux-2-flex",
                      "gaidy/gpt-image-1-5",
                      "gaidy/grok-imagine",
                      "gaidy/qwen-image",
                      "gaidy/gpt-5-image-mini",
                      "gaidy/gpt-5-image",
                      "gaidy/gpt-5-4-image-2",
                      "gaidy/nanobanano-pro",
                      "gaidy/nanobanano-2",
                      "gaidy/nanobanano"
                    ]
                  },
                  {
                    "group": "Аудио",
                    "icon": "volume-high",
                    "pages": [
                      "gaidy/elevenlabs-tts-turbo",
                      "gaidy/elevenlabs-tts-multilingual"
                    ]
                  },
                  {
                    "group": "Музыка",
                    "icon": "music",
                    "pages": [
                      "gaidy/suno-music"
                    ]
                  }
                ]
              },
              {
                "group": "Интеграции",
                "pages": [
                  "gaidy/claude-code",
                  "gaidy/cline",
                  "gaidy/kilo-code",
                  "gaidy/dify",
                  "gaidy/roo-code",
                  "gaidy/n8n",
                  "gaidy/opencode",
                  "gaidy/openclaw",
                  "gaidy/qwen-code"
